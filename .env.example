# GEMINI_API_KEY: Required for Gemini AI API calls.
# Store this only on the server side. Do not expose it to the browser bundle.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL: Gemini model name used by the server.
# As of April 8, 2026, Google's official Gemini API docs list gemini-3-flash-preview.
GEMINI_MODEL="gemini-3-flash-preview"

# ALLOWED_ORIGIN: Optional CORS allowlist if the frontend and API are hosted on different origins.
# Example: https://your-frontend.example.com
ALLOWED_ORIGIN=""

# VITE_CHAT_API_URL: Optional browser-side override when your API lives on another origin.
# Leave this empty for same-origin hosting.
VITE_CHAT_API_URL=""
